{
  "name": "@agent-native/pinpoint",
  "version": "0.1.10",
  "description": "Visual feedback and annotation tool for agent-native web applications",
  "homepage": "https://github.com/studio-jami/jami-studio#readme",
  "bugs": {
    "url": "https://github.com/studio-jami/jami-studio/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/studio-jami/jami-studio",
    "directory": "packages/pinpoint"
  },
  "bin": {
    "pinpoint": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src/scripts",
    ".agents"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.browser.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsgo --noEmit",
    "test": "vitest --run --passWithNoTests"
  },
  "dependencies": {
    "@medv/finder": "^4.0.2",
    "bippy": "^0.5.32",
    "element-source": "^0.0.3",
    "solid-js": "^1.9.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@agent-native/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.2.1",
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "catalog:",
    "babel-preset-solid": "^1.9.10",
    "esbuild-plugin-solid": "^0.6.0",
    "express": "^5.1.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@agent-native/core": ">=0.8.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
