{
  "name": "@agent-native/embedding",
  "version": "0.2.0",
  "description": "Embed Agent-Native apps, pickers, and agents inside other apps.",
  "homepage": "https://github.com/studio-jami/jami-studio#readme",
  "bugs": {
    "url": "https://github.com/studio-jami/jami-studio/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/studio-jami/jami-studio",
    "directory": "packages/embedding"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "test": "vitest --run src",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@agent-native/core": "workspace:*",
    "@types/react": "^19.2.15",
    "@typescript/native-preview": "catalog:",
    "react": "^19.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@agent-native/core": ">=0.22.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
