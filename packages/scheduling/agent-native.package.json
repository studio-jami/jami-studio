  "schemaEntryPoint": "@agent-native/scheduling/schema",
  "docs": {
    "llms": "docs/llms.txt",
    "llmsFull": "docs/llms-full.txt",
    "skills": [
      "scheduling-basics",
      "event-types",
      "availability",
