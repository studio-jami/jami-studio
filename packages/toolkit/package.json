{
  "name": "@agent-native/toolkit",
  "version": "0.4.2",
  "description": "Reusable app-building UI and helpers for Agent-Native apps.",
  "homepage": "https://github.com/BuilderIO/agent-native#readme",
  "bugs": {
    "url": "https://github.com/BuilderIO/agent-native/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BuilderIO/agent-native",
    "directory": "packages/toolkit"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./app-shell": {
      "types": "./dist/app-shell/index.d.ts",
      "import": "./dist/app-shell/index.js",
      "default": "./dist/app-shell/index.js"
    },
    "./app-shell/*": {
      "types": "./dist/app-shell/*.d.ts",
      "import": "./dist/app-shell/*.js",
      "default": "./dist/app-shell/*.js"
    },
    "./collab-ui": {
      "types": "./dist/collab-ui/index.d.ts",
      "import": "./dist/collab-ui/index.js",
      "default": "./dist/collab-ui/index.js"
    },
    "./collab-ui/*": {
      "types": "./dist/collab-ui/*.d.ts",
      "import": "./dist/collab-ui/*.js",
      "default": "./dist/collab-ui/*.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "default": "./dist/hooks/index.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js",
      "default": "./dist/hooks/*.js"
    },
    "./onboarding": {
      "types": "./dist/onboarding/index.d.ts",
      "import": "./dist/onboarding/index.js",
      "default": "./dist/onboarding/index.js"
    },
    "./onboarding/*": {
      "types": "./dist/onboarding/*.d.ts",
      "import": "./dist/onboarding/*.js",
      "default": "./dist/onboarding/*.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js",
      "default": "./dist/provider.js"
    },
    "./sharing": {
      "types": "./dist/sharing/index.d.ts",
      "import": "./dist/sharing/index.js",
      "default": "./dist/sharing/index.js"
    },
    "./sharing/*": {
      "types": "./dist/sharing/*.d.ts",
      "import": "./dist/sharing/*.js",
      "default": "./dist/sharing/*.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    },
    "./ui/*": {
      "types": "./dist/ui/*.d.ts",
      "import": "./dist/ui/*.js",
      "default": "./dist/ui/*.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "default": "./dist/utils.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsgo && node scripts/finalize-build.mjs",
    "prepublishOnly": "npm run build",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-collapsible": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.3.2",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-hover-card": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.19",
    "@radix-ui/react-navigation-menu": "^1.2.17",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-toast": "^1.2.18",
    "@radix-ui/react-toggle": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tabler/icons-react": "^3.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "next-themes": "^0.4.6",
    "react-day-picker": "^10.0.1",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.12.1",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "catalog:",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
