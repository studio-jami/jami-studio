{
  "name": "agent-native",
  "displayName": "Jami Studio",
  "version": "0.0.2",
  "description": "Open Jami Studio Plans, Design, and MCP handoff links inside VS Code.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "agent-native",
    "coding agents",
    "design",
    "mcp",
    "plans",
    "visual plans"
  ],
  "homepage": "https://jami.studio/docs/template-plan#vscode-extension",
  "bugs": {
    "url": "https://github.com/BuilderIO/agent-native/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BuilderIO/agent-native.git",
    "directory": "packages/vscode-extension"
  },
  "publisher": "Builder",
  "type": "commonjs",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest --run src --passWithNoTests",
    "test:e2e": "pnpm run build && node dist/test/runTest.js",
    "vscode:prepublish": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "1.120.0",
    "@vscode/test-electron": "3.0.0",
    "typescript": "catalog:",
    "typescript-7": "catalog:",
    "vitest": "catalog:"
  },
  "contributes": {
    "commands": [
      {
        "command": "agentNative.openDefaultApp",
        "title": "Open Agent Native",
        "category": "Agent Native"
      },
      {
        "command": "agentNative.openUrl",
        "title": "Open Agent Native URL",
        "category": "Agent Native"
      },
      {
        "command": "agentNative.connectWorkspace",
        "title": "Connect Workspace to Agent Native MCP",
        "category": "Agent Native"
      },
      {
        "command": "agentNative.openDesignCanvas",
        "title": "Open Design Canvas",
        "category": "Agent Native"
      }
    ],
    "configuration": {
      "title": "Agent Native",
      "properties": {
        "agentNative.defaultAppUrl": {
          "type": "string",
          "default": "https://plan.jami.studio",
          "description": "The Agent Native app URL opened by the Open Agent Native command."
        }
      }
    }
  },
  "activationEvents": [
    "onCommand:agentNative.connectWorkspace",
    "onCommand:agentNative.openDefaultApp",
    "onCommand:agentNative.openDesignCanvas",
    "onCommand:agentNative.openUrl",
    "onUri"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.120.0"
  }
}
