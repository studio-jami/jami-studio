{
  "expo": {
    "name": "Agent Native",
    "slug": "agent-native-mobile",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "agentnative",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.agentnative.mobile",
      "supportsTablet": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.agentnative.mobile"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSupportsLiveActivities": true
      }
    },
    "android": {
      "package": "com.agentnative.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "@bacons/apple-targets",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Agent Native to show meetings you choose to prepare for recording."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Agent Native to record dictation, meetings, and audio notes you start.",
          "enableBackgroundRecording": true,
          "enableBackgroundPlayback": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Agent Native to record videos you choose to share.",
          "microphonePermission": "Allow Agent Native to record sound with your videos.",
          "barcodeScannerEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Agent Native to import videos you choose from your library.",
          "cameraPermission": "Allow Agent Native to record videos you choose to share.",
          "microphonePermission": "Allow Agent Native to record sound with your videos."
        }
      ],
      [
        "expo-notifications",
        {
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "./plugins/with-mobile-companion",
      "./plugins/with-ios-app-intents",
      "./plugins/with-ios-companion",
      "./plugins/with-android-capture-tile"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b359544d-d83a-4384-8837-d87c02facba6"
      }
    },
    "owner": "steve8708"
  }
}
