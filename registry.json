        {
          "path": ".agents/skills/context-awareness/SKILL.md",
          "type": "registry:file",
          "target": "~/.agents/skills/context-awareness/SKILL.md"
        },
        {
          "path": ".agents/skills/real-time-sync/SKILL.md",
