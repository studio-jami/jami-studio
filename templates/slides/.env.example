# Add API keys only in your local .env, deployment secrets, or Settings.
# Never commit real API keys, tokens, webhook URLs, signing secrets, or private data.
# GOOGLE_API_KEY=
# GOOGLE_SEARCH_CX=

# Gemini — used for AI image generation in slides
# GEMINI_API_KEY=

# Brandfetch — used for brand logo and color lookups
# BRANDFETCH_CLIENT_ID=

# Logo.dev — alternative logo provider
# LOGO_DEV_TOKEN=
# LOGO_DEV_SECRET_KEY=

# Database — defaults to local SQLite (file:./data/app.db)
# Set to a remote URL for cloud database (e.g. libsql://your-db.turso.io)
# DATABASE_URL=
# DATABASE_AUTH_TOKEN=
